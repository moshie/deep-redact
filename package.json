{
	"name": "deep-redact",
	"version": "1.0.15",
	"description": "Deeply redact sensitive data from JS primitives",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/moshie/deep-redact.git"
	},
	"scripts": {
		"bench": "pnpm build && node benchmark.mjs",
		"build": "tsdown src/index.ts --format esm,cjs --dts",
		"release": "pnpm build && changeset publish",
		"coverage": "vitest run --coverage",
		"test": "vitest run --typecheck",
		"test:watch": "vitest --typecheck",
		"lint": "biome lint --write src/",
		"format": "biome format src/",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist/"
	],
	"keywords": [
		"blacklist",
		"sensitive",
		"redaction",
		"redactor",
		"secrets",
		"censor",
		"redact",
		"deep",
		"data",
		"json"
	],
	"bugs": {
		"url": "https://github.com/moshie/deep-redact/issues",
		"email": "hello@moshie.dev"
	},
	"homepage": "https://github.com/moshie/deep-redact",
	"author": {
		"name": "David Hewitt",
		"email": "hello@moshie.dev",
		"url": "https://cv.moshie.dev/"
	},
	"license": "MIT",
	"dependencies": {
		"is-url": "1.2.4",
		"qs": "6.15.1",
		"relaxed-json": "1.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@changesets/cli": "^2.30.0",
		"@types/benchmark": "^2.1.5",
		"@types/is-url": "^1.2.32",
		"@types/qs": "^6.15.0",
		"@types/relaxed-json": "^1.0.4",
		"@vitest/coverage-v8": "^4.1.4",
		"benchmark": "^2.1.4",
		"lefthook": "^2.1.5",
		"rimraf": "^6.1.3",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook",
			"esbuild"
		]
	},
	"packageManager": "pnpm@10.33.0"
}
